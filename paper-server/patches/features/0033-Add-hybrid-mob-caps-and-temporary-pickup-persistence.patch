+private boolean paper$isEligibleForTemporaryPickupPersistence(ServerLevel level) {
+    final io.papermc.paper.configuration.WorldConfiguration.Entities.Spawning.PickupPersistenceExpiry config =
+        level.paperConfig().entities.spawning.pickupPersistenceExpiry;
+
+    if (!config.enabled || config.ticks <= 0) {
+        return false;
+    }
+    if (config.monstersOnly && this.getType().getCategory() != MobCategory.MONSTER) {
+        return false;
+    }
+    if (config.naturalAndChunkGenerationOnly) {
+        final org.bukkit.event.entity.CreatureSpawnEvent.SpawnReason spawnReason = this.spawnReason;
+        if (spawnReason == null) {
+            return false;
+        }
+        if (spawnReason != org.bukkit.event.entity.CreatureSpawnEvent.SpawnReason.NATURAL
+            && spawnReason != org.bukkit.event.entity.CreatureSpawnEvent.SpawnReason.CHUNK_GEN) {
+            return false;
+        }
     }
